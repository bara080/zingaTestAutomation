{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-native",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["zinga/Frontend/*"]
    },
    "types": ["jest", "node"]
  },
  "include": [
    "unit/**/*",
    "component/**/*",
    "integration/**/*",
    "helpers/**/*",
    "fixtures/**/*"
  ],
  "exclude": ["node_modules", "zinga", "e2e", "coverage"]
}
